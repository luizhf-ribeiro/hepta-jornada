# Ambiente HEPTA Jornada
HEPTA_HOST=0.0.0.0
PORT=8000
HEPTA_CORPORATE_DOMAIN=@hepta.com.br
HEPTA_SESSION_MINUTES=720

# Banco local fallback: SQLite
HEPTA_DB_PATH=hepta_jornada.db
HEPTA_UPLOAD_DIR=uploads
HEPTA_BACKUP_DIR=backups

# Banco Supabase/PostgreSQL - usar no Render
# Cole aqui a connection string do Supabase em Project Settings > Database > Connection string
# Exemplo: postgresql://postgres.xxxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=
# Alternativa aceita pelo app:
SUPABASE_DB_URL=

# Regras jornada
HEPTA_FIRST_BUSINESS_DAY_DEADLINE=21:00
HEPTA_LEGAL_TOLERANCE_PER_MARK_MIN=5
HEPTA_LEGAL_TOLERANCE_DAY_MIN=10
HEPTA_MANAGEMENT_DELAY_ALERT_MIN=15

# SMTP - homologação pode deixar vazio; e-mails serão simulados no log
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS=1
